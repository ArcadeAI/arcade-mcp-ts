# Arcade settings
ARCADE_API_KEY=
ARCADE_API_URL=https://api.arcade.dev
ARCADE_WORKER_SECRET=
ARCADE_USER_ID=

# MCP Server settings
MCP_SERVER_NAME=ArcadeMCP
MCP_SERVER_VERSION=0.1.0
MCP_SERVER_TITLE=
MCP_SERVER_INSTRUCTIONS=

# MCP Transport settings
MCP_TRANSPORT_SESSION_TIMEOUT_SECONDS=300
MCP_TRANSPORT_MAX_SESSIONS=1000

# MCP Middleware settings
MCP_MIDDLEWARE_ENABLE_LOGGING=true
MCP_MIDDLEWARE_LOG_LEVEL=INFO
MCP_MIDDLEWARE_ENABLE_ERROR_HANDLING=true
MCP_MIDDLEWARE_MASK_ERROR_DETAILS=false

# MCP Resource Server settings (JSON array for authorization_servers)
MCP_RESOURCE_SERVER_CANONICAL_URL=
MCP_RESOURCE_SERVER_AUTHORIZATION_SERVERS=

# Tool secrets (any env var not prefixed with MCP_ or _ is available as a tool secret)
# GITHUB_TOKEN=
# SLACK_TOKEN=
